# Copy this file to `.env` and adjust for your environment.

# --- General ---
APP_NAME=Lumora RAG API
DEBUG=true

# --- Networking ---
HOST=0.0.0.0
PORT=8000
# Comma separated list of allowed origins. Use a real domain in production.
CORS_ORIGINS=*

# --- Security (CHANGE THESE IN PRODUCTION) ---
SECRET_KEY=please-change-me-to-a-long-random-string-32chars-min
ACCESS_TOKEN_EXPIRE_MINUTES=720
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- Models ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_TEMPERATURE=0.2
DEFAULT_TOP_K=4
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# --- Uploads ---
MAX_UPLOAD_MB=50

# --- Rate limiting (chat endpoint) ---
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# --- Paths (optional overrides; default to the project root) ---
# DATA_DIR=../data
# CHROMA_DIR=../chroma_db
